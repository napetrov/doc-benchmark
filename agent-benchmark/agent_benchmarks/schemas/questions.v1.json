{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/napetrov/agent-benchmark/schemas/questions.v1.json",
  "title": "Questions artifact v1",
  "type": "object",
  "required": [
    "questions"
  ],
  "properties": {
    "schema_version": {
      "const": "questions.v1"
    },
    "library": {
      "type": "string"
    },
    "library_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": [
              "string",
              "integer"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "persona": {
            "type": [
              "string",
              "object",
              "null"
            ]
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "difficulty": {
            "type": [
              "string",
              "integer",
              "number",
              "null"
            ]
          },
          "expected_topics": {
            "type": "array"
          }
        }
      }
    }
  }
}
