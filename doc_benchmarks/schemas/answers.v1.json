{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/napetrov/doc-benchmark/schemas/answers.v1.json",
  "title": "Answers artifact v1",
  "type": "object",
  "required": ["answers"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "model": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "total_questions": { "type": "integer" },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id"],
        "properties": {
          "question_id": { "type": ["string", "integer"] },
          "question_text": { "type": "string" },
          "library_name": { "type": ["string", "null"] },
          "with_docs": { "type": ["object", "null"] },
          "without_docs": { "type": ["object", "null"] }
        }
      }
    }
  }
}
